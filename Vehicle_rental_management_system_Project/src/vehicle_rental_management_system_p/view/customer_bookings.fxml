<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #FFF8F3;" stylesheets="@../resources/tangerra-style.css" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vehicle_rental_management_system_p.CustomerBookingsController">

    <!-- Top: Tangerra Header -->
    <top>
        <VBox style="-fx-background-color: #EA5B2B; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="My Bookings" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblCustomerName" style="-fx-text-fill: white; -fx-font-size: 16px;" text="Customer" />
                <Button fx:id="btnBack" onAction="#handleBack" style="-fx-background-color: #C74D23; -fx-text-fill: white; -fx-font-size: 14px;" text="← Back to Dashboard" />
            </HBox>
        </VBox>
    </top>

    <!-- Left: Filter Options -->
    <left>
        <VBox prefWidth="250" spacing="15.0" style="-fx-background-color: #F5F5F0; -fx-padding: 20;">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>

            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #EA5B2B;" text="Filter Bookings" />
            <Separator />

            <VBox spacing="8.0">
                <Label text="Status:" />
                <ComboBox fx:id="cbFilterStatus" prefWidth="200.0" promptText="All Bookings" />
            </VBox>

            <Button fx:id="btnRefresh" onAction="#handleRefresh" prefWidth="200.0" style="-fx-background-color: #EA5B2B; -fx-text-fill: white;" text="Refresh" />

            <Separator />

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #EA5B2B;" text="Quick Actions" />

            <Button fx:id="btnNewBooking" onAction="#handleNewBooking" prefWidth="200.0" style="-fx-background-color: #FF7445; -fx-text-fill: white; -fx-padding: 10;" text="Book New Vehicle" />

            <Region VBox.vgrow="ALWAYS" />

            <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #EA5B2B;" text="Summary" />
                <HBox alignment="CENTER_LEFT">
                    <Label text="Active Rentals:" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblActiveCount" style="-fx-font-weight: bold; -fx-text-fill: #EA5B2B;" text="0" />
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Total Bookings:" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblTotalCount" style="-fx-font-weight: bold; -fx-text-fill: #4A4A4A;" text="0" />
                </HBox>
            </VBox>
        </VBox>
    </left>

    <!-- Center: Bookings Table -->
    <center>
        <VBox spacing="15.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #EA5B2B;" text="Your Rental History" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotalRentals" style="-fx-font-size: 14px; -fx-text-fill: #EA5B2B;" text="Total: 0" />
            </HBox>

            <Separator />

            <TableView fx:id="tableRentals" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colRentalId" prefWidth="100.0" text="Booking ID" />
                    <TableColumn fx:id="colVehicle" prefWidth="250.0" text="Vehicle" />
                    <TableColumn fx:id="colRentalDate" prefWidth="130.0" text="Pickup Date" />
                    <TableColumn fx:id="colExpectedReturn" prefWidth="130.0" text="Return Date" />
                    <TableColumn fx:id="colActualReturn" prefWidth="130.0" text="Actual Return" />
                    <TableColumn fx:id="colTotalCost" prefWidth="120.0" text="Total Cost (SAR)" />
                    <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblMessage" style="-fx-text-fill: green; -fx-font-weight: bold;" text="" />
            </HBox>
        </VBox>
    </center>

    <!-- Right: Booking Details -->
    <right>
        <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <padding>
                <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
            </padding>

            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #EA5B2B;" text="Booking Details" />
            <Separator />

            <VBox fx:id="detailsPane" spacing="10">
                <Label style="-fx-text-fill: gray; -fx-font-style: italic;" text="Select a booking to view details" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox spacing="10">
                <Label fx:id="lblRentalId" style="-fx-font-weight: bold;" text="" />
                <Label fx:id="lblVehicleDetails" text="" wrapText="true" />
                <Label fx:id="lblDateDetails" text="" wrapText="true" />
                <Label fx:id="lblCostDetails" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #EA5B2B;" text="" />
                <Label fx:id="lblStatusDetails" style="-fx-font-weight: bold;" text="" />
            </VBox>

            <Separator />

            <Button fx:id="btnViewDetails" onAction="#handleViewDetails" prefWidth="250" style="-fx-background-color: #EA5B2B; -fx-text-fill: white;" text="View Full Details" />
        </VBox>
    </right>

</BorderPane>
